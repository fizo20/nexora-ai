{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "noImplicitAny": false,
    "strictNullChecks": false,
    "resolveJsonModule": true
  },

  "include": ["src", "src/utils/app-error.ts"],
  "exclude": ["node_modules", "dist"]
}
